        <form class="auth-form" id="loginForm" novalidate>

            <!-- Full Name -->
            <div class="field-group">
                <label class="field-label" for="fullname">Full Name</label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="fa-solid fa-user"></i></span>
                    <input class="auth-input" type="text" id="fullname" name="fullname"
                           placeholder="Your registered name" autocomplete="name" />
                </div>
                <div class="field-msg" id="name-msg"></div>
            </div>

            <!-- Password -->
            <div class="field-group">
                <label class="field-label" for="password">Password</label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="fa-solid fa-lock"></i></span>
                    <input class="auth-input" type="password" id="password" name="password"
                           placeholder="Enter your password" autocomplete="current-password"
                           style="padding-right: 42px;" />
                    <button type="button" class="pwd-toggle" id="pwdToggle">👁️</button>
                </div>
                <div class="field-msg" id="pwd-msg"></div>
            </div>

            <!-- Extras -->
            <div class="form-extras">
                <label class="remember-wrap">
                    <input type="checkbox" class="remember-check" id="rememberMe" />
                    <span>Remember me</span>
                </label>
                <a href="/Account/ForgotPassword" class="forgot-link">Forgot password?</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-submit" id="loginBtn">
                Sign In to DivineCRM →
            </button>

            <!-- Trust row -->
            <div class="trust-row">
                <div class="trust-badge">
                    <i class="fa-solid fa-lock"></i>
                    <span>Secure Login</span>
                </div>
                <div class="trust-badge">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>256-bit SSL</span>
                </div>
                <div class="trust-badge">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>500+ Teams</span>
                </div>
            </div>

        </form>
        <div class="auth-divider" style="margin-top: 20px;"><span>New to DivineCRM?</span></div>
        <div class="auth-footer" style="margin-top: 12px;">
            <a href="/Home/SignUp">Create a free account →</a>
        </div>
    </div>
</div>
