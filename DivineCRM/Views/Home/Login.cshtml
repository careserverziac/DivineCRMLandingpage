<script>
    // Password toggle
    const pwdInput = document.getElementById('password');
    document.getElementById('pwdToggle').addEventListener('click', function () {
        const show = pwdInput.type === 'password';
        pwdInput.type = show ? 'text' : 'password';
        this.textContent = show ? '🙈' : '👁️';
    });

    // Helper functions
    function showMsg(id, text) {
        const el = document.getElementById(id);
        el.textContent = text;
        el.className = 'field-msg show err';
    }

    function clearMsg(id) {
        const el = document.getElementById(id);
        el.textContent = '';
        el.className = 'field-msg';
    }

    // Clear error on typing
    document.getElementById('fullname').addEventListener('input', function () {
        clearMsg('name-msg');
        this.classList.remove('invalid');
    });

    document.getElementById('password').addEventListener('input', function () {
        clearMsg('pwd-msg');
        this.classList.remove('invalid');
    });

    // Submit handler
    document.getElementById('loginForm').addEventListener('submit', function (e) {
        e.preventDefault();

        const btn = document.getElementById('loginBtn');
        const nameInput = document.getElementById('fullname');
        const pwdInput = document.getElementById('password');

        let isValid = true;

        // Clear previous errors
        clearMsg('name-msg');
        clearMsg('pwd-msg');

        nameInput.classList.remove('invalid');
        pwdInput.classList.remove('invalid');

        // Name validation
        if (!nameInput.value.trim()) {
            showMsg('name-msg', 'Please enter your name');
            nameInput.classList.add('invalid');
            isValid = false;
        }

        // Password validation
        if (!pwdInput.value.trim()) {
            showMsg('pwd-msg', 'Please enter your password');
            pwdInput.classList.add('invalid');
            isValid = false;
        }

        // Stop if invalid
        if (!isValid) return;

        // Success flow
        btn.textContent = 'Signing in…';
        btn.disabled = true;

        // 👉 Connect to backend here
        // this.submit();

        // Demo success
        setTimeout(function () {
            btn.textContent = '✓ Signed In!';
            btn.style.background = 'linear-gradient(135deg,#10b981,#059669)';
        }, 1200);
    });
</script>