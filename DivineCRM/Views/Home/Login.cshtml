
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

@*<h2>Login</h2>*@


<div class="mesh-bg">
    <div class="mesh-orb orb1"></div>
    <div class="mesh-orb orb2"></div>
    <div class="mesh-orb orb3"></div>
</div>
<div class="auth-page">
    <div class="auth-card">
        @*<span class="auth-logo">✦ DivineCRM</span>*@
        <div class="auth-logo">
            <img src="~/Content/Images/logo_only_light (1).svg" alt="Logo Icon">
            <img src="~/Content/Images/logo_name_only_light.svg" alt="Logo Text">
        </div>
        <p class="auth-logo-sub">Smart CRM for Growing Sales Teams</p>
        <h1 class="auth-title"><span class="grad-text">Welcome</span> Back</h1>
        <p class="auth-sub">Sign in to your DivineCRM account</p>
        <div class="error-banner" id="errorBanner">
            Invalid credentials. Please check your name and password.
        </div>
        <form class="auth-form" id="loginForm" novalidate>
            <!-- Full Name -->
            <div class="field-group">
                <label class="field-label" for="fullname">Full Name</label>
                <div class="field-wrap">
                    @*<span class="field-icon">👤</span>*@
                    <span class="field-icon"><i class="fa-solid fa-user"></i></span>
                    <input class="auth-input" type="text" id="fullname" name="fullname" placeholder="Your registered name" autocomplete="name" />
                </div>
            </div>
            <!-- Password -->
            <div class="field-group">
                <label class="field-label" for="password">Password</label>
                <div class="field-wrap">
                    @*<span class="field-icon">🔒</span>*@
                    <span class="field-icon"><i class="fa-solid fa-lock"></i></span>
                    <input class="auth-input" type="password" id="password" name="password" placeholder="Enter your password" autocomplete="current-password" style="padding-right: 42px;" />
                    <button type="button" class="pwd-toggle" id="pwdToggle" aria-label="Toggle password">👁️</button>
                </div>
            </div>
            <!-- Extras -->
            <div class="form-extras">
                <label class="remember-wrap">
                    <input type="checkbox" class="remember-check" id="rememberMe" />
                    <span>Remember me</span>
                </label>
                <a href="/Account/ForgotPassword" class="forgot-link">Forgot password?</a>
            </div>
            <button type="submit" class="btn-submit" id="loginBtn">
                Sign In to DivineCRM →
            </button>
            <!-- Trust row -->
            @*<div class="trust-row">
            <div class="trust-badge">🔐 Secure Login</div>
            <div class="trust-badge">🛡️ 256-bit SSL</div>
            <div class="trust-badge">✅ 500+ Teams</div>
        </div>*@
            <div class="trust-row">
                <div class="trust-badge">
                    <i class="fa-solid fa-lock"></i>
                    <span>Secure Login</span>
                </div>
                <div class="trust-badge">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>256-bit SSL</span>
                </div>
                <div class="trust-badge">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>500+ Teams</span>
                </div>
            </div>
        </form>
        <div class="auth-divider" style="margin-top: 20px;"><span>New to DivineCRM?</span></div>
        <div class="auth-footer" style="margin-top: 12px;">
            <a href="/Home/SignUp">Create a free account →</a>
        </div>
    </div>
</div>
<script>// Password toggle
    const pwdInput = document.getElementById('password');
    document.getElementById('pwdToggle').addEventListener('click', function () {
        const show = pwdInput.type === 'password';
        pwdInput.type = show ? 'text' : 'password';
        this.textContent = show ? '🙈' : '👁️';
    });

    // Clear error on input
    [document.getElementById('fullname'), pwdInput].forEach(function (el) {
        el.addEventListener('input', function () {
            document.getElementById('errorBanner').classList.remove('show');
            el.style.borderColor = '';
        });
    });

    // Submit handler
    document.getElementById('loginForm').addEventListener('submit', function (e) {
        e.preventDefault();
        const btn = document.getElementById('loginBtn');
        const name = document.getElementById('fullname').value.trim();
        const pwd = document.getElementById('password').value;
        const errBanner = document.getElementById('errorBanner');

        if (!name || !pwd) {
            errBanner.textContent = 'Please enter your name and password.';
            errBanner.classList.add('show');
            errBanner.style.animation = 'none';
            void errBanner.offsetWidth;
            errBanner.style.animation = '';
            return;
        }

        btn.textContent = 'Signing in…';
        btn.disabled = true;

        // Hook up to your controller/action here:
        // this.submit();

        // Demo: simulate success
        setTimeout(function () {
            btn.textContent = '✓ Signed In!';
            btn.style.background = 'linear-gradient(135deg,#10b981,#059669)';
            btn.style.animation = 'successPop 0.4s ease';
        }, 1200);
    });
</script>
