
@{
    ViewBag.Title = "Blog";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<style>
    :root {
        --bg: #08090d;
        --bg2: #0d0f18;
        --text: #f0f2ff;
        --muted: #8892b0;
        --grad: linear-gradient(135deg,#4f6ef7,#7c3aed);
    }

    body {
        background: var(--bg);
        color: var(--text);
    }

    /* HERO */
    .blog-hero {
        position: relative;
        text-align: center;
        padding: 130px 5% 80px;
    }

    .hero-content {
        max-width: 800px;
        margin: auto;
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(79,110,247,0.12);
        border: 1px solid rgba(79,110,247,0.3);
        padding: 6px 16px;
        border-radius: 30px;
        color: #a5b4ff;
        font-size: 13px;
        margin-bottom: 20px;
    }

    .blog-hero h1 {
        font-size: clamp(34px,5vw,58px);
        font-weight: 800;
    }

    .grad-text {
        background: var(--grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .blog-hero p {
        color: var(--muted);
        margin-top: 15px;
    }

    /* BACKGROUND ORBS */
    .mesh-bg {
        position: absolute;
        inset: 0;
    }

    .mesh-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: .2;
    }

    .orb1 {
        width: 500px;
        height: 500px;
        background: #4f6ef7;
        top: -150px;
        left: -100px;
    }

    .orb2 {
        width: 500px;
        height: 500px;
        background: #7c3aed;
        right: -120px;
    }

    /* BLOG GRID */
    .blog-section {
        padding: 40px 5% 100px;
    }

    .blog-grid {
        max-width: 1100px;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(320px,1fr));
        gap: 28px;
    }

    /* CARD */
    .blog-card {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        text-decoration: none;
        color: white;
        border: 1px solid rgba(255,255,255,0.08);
        /*transition: .4s;*/
        transition: border .25s ease, transform .2s ease !important;
    }

        .blog-card:hover {
            transform: translateY(-4px) !important; /* subtle lift only */
            border: 1px solid #4f6ef7 !important; /* FORCE BLUE BORDER */
        }    
      

    /* GRADIENT BACKGROUNDS */
    .card-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg,#4f6ef7,#7c3aed);
        opacity: .15;
    }

        .card-bg.alt {
            background: linear-gradient(135deg,#06b6d4,#4f6ef7);
        }

        .card-bg.third {
            background: linear-gradient(135deg,#7c3aed,#ec4899);
        }

    /* CONTENT */
    .card-content {
        position: relative;
        padding: 28px;
    }

    .tag {
        font-size: 12px;
        color: #a5b4ff;
    }

    .blog-card h3 {
        margin: 10px 0;
        font-size: 20px;
        font-weight: 700;
    }

    .blog-card p {
        font-size: 14px;
        color: var(--muted);
    }

    .meta {
        margin-top: 14px;
        font-size: 12px;
        color: #a5b4ff;
    }

    /* ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: .7s;
    }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
</style>
<section class="blog-hero">
    <div class="mesh-bg">
        <div class="mesh-orb orb1"></div>
        <div class="mesh-orb orb2"></div>
    </div>

    <div class="hero-content">
        <div class="hero-badge">Insights & Resources</div>
        <h1>Learn CRM, Sales & <span class="grad-text">Business Growth</span></h1>
        <p>Explore expert guides on lead management, sales optimization and CRM strategies to grow your business.</p>
    </div>
</section>

<section class="blog-section">
    <div class="blog-grid">

        <!-- CARD 1 -->
        <a href="/Home/CRMvsExcel" class="blog-card reveal">
            <div class="card-bg"></div>
            <div class="card-content">
                <span class="tag">Comparison</span>
                <h3>CRM vs Excel — Which is Better?</h3>
                <p>Compare CRM software and Excel for managing leads, follow-ups and sales growth.</p>
                <div class="meta"> Readmore → </div>
            </div>
        </a>

        <!-- CARD 2 -->
        <a href="/Home/HowToImproveSale" class="blog-card reveal">
            <div class="card-bg alt"></div>
            <div class="card-content">
                <span class="tag">Guide</span>
                <h3>How to Improve Sales Follow-Ups</h3>
                <p>Learn proven strategies to improve follow-ups and close more deals faster.</p>
                <div class="meta"> Readmore → </div>
            </div>
        </a>

        <!-- CARD 3 -->
        <a href="/Home/SmallBusinesses" class="blog-card reveal">
            <div class="card-bg third"></div>
            <div class="card-content">
                <span class="tag">CRM</span>
                <h3>Why Your Business Needs a Sales CRM</h3>
                <p>Understand how CRM helps manage leads, automate tasks and increase revenue.</p>
                <div class="meta"> Readmore → </div>
            </div>
        </a>

    </div>
</section>

<script>
const observer = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
        if(entry.isIntersecting){
            entry.target.classList.add('visible');
        }
    });
},{threshold:0.1});

document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>