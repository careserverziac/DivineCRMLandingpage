
@{
    ViewBag.Title = "Blog";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<style>
    /* ── BLOG ULTRA PREMIUM ── */

    .blog-container {
        max-width: 900px;
        margin: auto;
        position: relative;
        z-index: 2;
    }

    /* Glass main wrapper */
    .blog-container {
        background: linear-gradient(145deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 50px 40px;
        backdrop-filter: blur(14px);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    }

        /* ── HEADINGS ── */
        .blog-container h2 {
            font-size: 34px;
            font-weight: 800;
            margin-bottom: 25px;
            line-height: 1.3;
        }

        .blog-container h3 {
            font-size: 24px;
            margin-top: 50px;
            margin-bottom: 18px;
            position: relative;
            padding-left: 14px;
        }

            /* Gradient left border for sections */
            .blog-container h3::before {
                content: "";
                position: absolute;
                left: 0;
                top: 5px;
                width: 4px;
                height: 20px;
                border-radius: 10px;
                background: var(--grad);
            }

        .blog-container h4 {
            font-size: 18px;
            margin-top: 25px;
            margin-bottom: 10px;
        }

        /* ── PARAGRAPH ── */
        .blog-container p {
            font-size: 15.5px;
            line-height: 1.9;
            color: var(--muted);
        }

    /* ── LIST (PREMIUM CHECK STYLE) ── */
    .blog-list li {
        position: relative;
        padding-left: 26px;
    }

        .blog-list li::before {
            content: "✓";
            position: absolute;
            left: 0;
            top: 0;
            font-size: 12px;
            font-weight: bold;
            color: #4f6ef7;
            background: rgba(79,110,247,0.1);
            border: 1px solid rgba(79,110,247,0.4);
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    /* ── BLOG HIGHLIGHT CARD ── */
    .blog-card {
        background: linear-gradient(145deg, rgba(79,110,247,0.08), rgba(124,58,237,0.05));
        border: 1px solid rgba(79,110,247,0.25);
        border-radius: 18px;
        padding: 24px;
        margin: 25px 0;
        position: relative;
        overflow: hidden;
    }

        .blog-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(79,110,247,0.15), transparent 60%);
        }

    /* ── BENEFIT CARDS ── */
    .blog-grid {
        display: grid;
        gap: 20px;
        margin-top: 30px;
    }

    .blog-g4 {
        grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
    }

    .blog-adv-card {
        background: linear-gradient(145deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 26px;
        text-align: center;
        transition: all .35s ease;
        position: relative;
        overflow: hidden;
    }

        .blog-adv-card:hover {
            transform: translateY(-6px) scale(1.02);
            border-color: rgba(79,110,247,0.5);
            box-shadow: 0 20px 50px rgba(79,110,247,0.2);
        }

    .blog-adv-icon {
        font-size: 24px;
        margin-bottom: 10px;
        background: var(--grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ── COMPARE CARDS ── */
    .blog-compare-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
        gap: 20px;
        margin-top: 25px;
    }

    .blog-compare-card {
        border-radius: 18px;
        padding: 26px;
        border: 1px solid var(--card-border);
        position: relative;
        overflow: hidden;
        transition: .3s;
    }

        /* RED CARD */
        .blog-compare-card.bad {
            background: linear-gradient(145deg, rgba(255,0,0,0.08), rgba(255,0,0,0.02));
            border-color: rgba(255,0,0,0.2);
        }

            .blog-compare-card.bad:hover {
                box-shadow: 0 20px 40px rgba(255,0,0,0.15);
            }

        /* BLUE CARD */
        .blog-compare-card.good {
            background: linear-gradient(145deg, rgba(79,110,247,0.12), rgba(124,58,237,0.05));
            border-color: rgba(79,110,247,0.3);
        }

            .blog-compare-card.good:hover {
                box-shadow: 0 20px 40px rgba(79,110,247,0.2);
            }

    /* ── CTA UPGRADE ── */
    .blog-final-cta {
        margin-top: 80px;
        border-radius: 20px;
        padding: 80px 20px;
        background: radial-gradient(circle at center, rgba(79,110,247,0.15), transparent 70%);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .blog-btn-primary {
        background: var(--grad);
        box-shadow: 0 10px 40px rgba(79,110,247,0.5);
        transition: .3s;
    }

        .blog-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 50px rgba(79,110,247,0.7);
        }

    .blog-btn-outline:hover {
        border-color: #4f6ef7;
        background: rgba(79,110,247,0.08);
    }

    .blog-wrap {
        max-width: 1100px;
        margin: auto;
    }

    .blog-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--card-border);
        border-radius: 18px;
        padding: 28px;
        margin-top: 25px;
    }

        .blog-card.big {
            padding: 35px;
        }

        .blog-card.danger {
            border-color: rgba(255,0,0,0.2);
            background: rgba(255,0,0,0.05);
        }

        .blog-card p {
            color: var(--muted);
            font-size: 15px;
            line-height: 1.8;
            margin-bottom: 12px;
        }

    .blog-note {
        margin-top: 15px;
        color: var(--muted2);
    }

    .blog-compare {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap: 20px;
        margin-top: 40px;
    }

    .blog-compare-card {
        border-radius: 18px;
        padding: 28px;
        border: 1px solid var(--card-border);
    }

        .blog-compare-card.bad {
            background: rgba(255,0,0,0.05);
        }

        .blog-compare-card.good {
            background: rgba(79,110,247,0.08);
        }
    /* FORCE 2-COLUMN FOR BLOG CONTENT */
    .blog-grid-2 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px,1fr));
        gap: 20px;
        margin-top: 25px;
    }

    /* SMALL CARDS */
    .blog-mini-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 22px;
        transition: .3s;
    }

        .blog-mini-card:hover {
            transform: translateY(-4px);
            border-color: rgba(79,110,247,0.4);
        }

        /* TITLE INSIDE CARD */
        .blog-mini-card h4 {
            margin-bottom: 10px;
            font-size: 16px;
        }

    /* IMPROVE SECTION SPACING */
    .blog-wrap section,
    .blog-wrap > div {
        margin-top: 20px;
    }

    /* FORCE CONSISTENT GRID SYSTEM */
    .grid {
        display: grid;
        gap: 20px;
        margin-top: 25px;
    }

    .g2 {
        grid-template-columns: repeat(auto-fit, minmax(280px,1fr));
    }

    .g3 {
        grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
    }

    .g4 {
        grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
    }

    /* FIX LIST STYLE */
    .ind-feat-list {
        list-style: none;
        padding: 0;
        margin-top: 10px;
    }

        .ind-feat-list li {
            position: relative;
            padding-left: 26px;
            margin-bottom: 10px;
            color: var(--muted);
        }

            .ind-feat-list li::before {
                content: "✓";
                position: absolute;
                left: 0;
                top: 2px;
                width: 18px;
                height: 18px;
                font-size: 12px;
                border-radius: 50%;
                background: rgba(79,110,247,0.1);
                border: 1px solid rgba(79,110,247,0.4);
                display: flex;
                align-items: center;
                justify-content: center;
                color: #4f6ef7;
            }

    /* MINI CARD */
    .blog-split-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 22px;
        transition: .3s;
    }

        .blog-split-card:hover {
            transform: translateY(-5px);
            border-color: rgba(79,110,247,0.4);
        }

    /* ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all .7s ease;
    }

        .reveal.visible {
            opacity: 1;
            transform: none;
        }

    /* STAGGER */
    .d1 {
        transition-delay: .1s;
    }

    .d2 {
        transition-delay: .2s;
    }

    .d3 {
        transition-delay: .3s;
    }

    .d4 {
        transition-delay: .4s;
    }
</style>


