
@{
    ViewBag.Title = "WhatIsCRM";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}





<style>
    /* ================= ROOT ================= */
.crm-page {
    --bg: #08090d;
    --bg2: #0d0f18;
    --bg3: #111420;
    --card-border: rgba(255,255,255,0.07);

    --accent: #4f6ef7;
    --accent2: #7c3aed;
    --accent3: #06b6d4;

    --grad: linear-gradient(135deg, #4f6ef7, #7c3aed);

    --text: #f0f2ff;
    --muted: #8892b0;
}

/* ================= BASE ================= */
.crm-page {
    background: var(--bg);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
}

/* ================= ANIMATIONS ================= */
@@keyframes crmFadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
}

@@keyframes crmShimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
}

@@keyframes crmFloat {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
}

/* ================= HERO ================= */
.crm-page .blog-hero {
    position: relative;
    padding: 130px 5% 80px;
    text-align: center;
    overflow: hidden;
}

.crm-page .blog-hero-inner {
    max-width: 820px;
    margin: auto;
}

.crm-page .hero-badge {
    background: rgba(79,110,247,0.12);
    border: 1px solid rgba(79,110,247,0.3);
    color: #a5b4ff;
    padding: 6px 16px;
    border-radius: 30px;
    font-size: 13px;
    margin-bottom: 20px;
    display: inline-block;
    animation: crmFadeUp .6s ease both;
}

.crm-page .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    display: inline-block;
}

.crm-page .blog-hero h1 {
    font-size: clamp(32px,4vw,56px);
    font-weight: 800;
    line-height: 1.2;
    animation: crmFadeUp .7s ease .1s both;
}

.crm-page .grad-text {
    background: linear-gradient(135deg,#4f6ef7,#a78bfa,#06b6d4);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: crmShimmer 4s linear infinite;
}

.crm-page .hero-desc {
    color: var(--muted);
    margin-top: 15px;
}

/* ================= ORBS ================= */
.crm-page .mesh-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.2;
}

.crm-page .orb1 {
    width: 500px;
    height: 500px;
    background: var(--accent);
    top: -200px;
    left: -100px;
    animation: crmFloat 8s infinite;
}

.crm-page .orb2 {
    width: 450px;
    height: 450px;
    background: var(--accent2);
    right: -150px;
    top: 0;
    animation: crmFloat 10s infinite reverse;
}

.crm-page .orb3 {
    width: 350px;
    height: 350px;
    background: var(--accent3);
    bottom: 0;
    left: 30%;
    animation: crmFloat 12s infinite;
}

/* ================= LAYOUT ================= */
.crm-page .blog-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    padding: 60px 5%;
}

/* ================= CARDS ================= */
.crm-page .benefit-block,
.crm-page .article-intro,
.crm-page .verdict-banner,
.crm-page .sidebar-card,
.crm-page .sidebar-cta {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.3s ease;
}

.crm-page .benefit-block:hover,
.crm-page .sidebar-card:hover,
.crm-page .verdict-banner:hover {
    border-color: rgba(79,110,247,0.5);
    box-shadow: 0 12px 40px rgba(79,110,247,0.25);
    transform: translateY(-4px);
}

/* ================= TEXT ================= */
.crm-page .section-tag {
    background: rgba(79,110,247,0.1);
    border: 1px solid rgba(79,110,247,0.25);
    color: #a5b4ff;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
}

.crm-page .art-h2 {
    font-size: 26px;
    font-weight: 800;
    margin: 30px 0 10px;
}

.crm-page .art-p {
    color: var(--muted);
}

/* ================= LIST ================= */
.crm-page .art-list li {
    display: flex;
    gap: 8px;
}

.crm-page .art-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--grad);
    border-radius: 50%;
    margin-top: 7px;
}

/* ================= TABLE ================= */
.crm-page .art-table th {
    background: rgba(79,110,247,0.08);
}

.crm-page .art-table td {
    border-bottom: 1px solid var(--card-border);
}

/* ================= BUTTON ================= */
.crm-page .btn-primary {
    background: var(--grad);
    padding: 12px 20px;
    border-radius: 30px;
    color: #fff;
    text-decoration: none;
    display: inline-block;
    font-weight: 600;
    box-shadow: 0 8px 30px rgba(79,110,247,0.4);
    transition: 0.2s;
}

.crm-page .btn-primary:hover {
    transform: translateY(-2px);
}

/* ================= SIDEBAR ================= */
.crm-page .blog-sidebar {
    position: sticky;
    top: 90px;
}

/* ================= REVEAL ================= */
.crm-page .reveal {
    opacity: 0;
    transform: translateY(35px);
    transition: .7s;
}

.crm-page .reveal.visible {
    opacity: 1;
    transform: none;
}

/* ================= FINAL CTA ================= */
.crm-page .final-cta {
    background: var(--bg2);
    text-align: center;
    padding: 100px 5%;
}

.crm-page .btn-cta-primary {
    background: var(--grad);
    padding: 14px 30px;
    border-radius: 30px;
    color: #fff;
}

/* ================= RESPONSIVE ================= */
@@media (max-width: 1024px) {
    .crm-page .blog-layout {
        grid-template-columns: 1fr;
    }

    .crm-page .blog-sidebar {
        position: static;
    }
}

@@media (max-width: 768px) {
    .crm-page .blog-hero h1 {
        font-size: 28px;
    }
}
</style>

